<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>You Are Here</string>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<!-- Live Activities -->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>

	<!-- Location -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Shows the town, road, heading, and altitude around you.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Keeps naming where you are — town, road, heading, altitude — even with the screen locked, so you don’t have to open Maps.</string>

	<!-- Barometric altimeter -->
	<key>NSMotionUsageDescription</key>
	<string>Uses the barometer for smooth, accurate altitude.</string>

	<!-- Bundled UI typefaces (Settings > Font) -->
	<key>UIAppFonts</key>
	<array>
		<string>FSMillbankWeb.ttf</string>
		<string>FSMillbankWeb-Bold.ttf</string>
		<string>Overpass-Regular.ttf</string>
		<string>Overpass-Medium.ttf</string>
		<string>Overpass-SemiBold.ttf</string>
		<string>Overpass-Bold.ttf</string>
		<string>Barlow-Regular.ttf</string>
		<string>Barlow-Medium.ttf</string>
		<string>Barlow-SemiBold.ttf</string>
		<string>Barlow-Bold.ttf</string>
		<string>Inter-Regular.ttf</string>
		<string>Inter-Medium.ttf</string>
		<string>Inter-SemiBold.ttf</string>
		<string>Inter-Bold.ttf</string>
		<string>B612-Regular.ttf</string>
		<string>B612-Bold.ttf</string>
		<string>AtkinsonHyperlegible-Regular.ttf</string>
		<string>AtkinsonHyperlegible-Bold.ttf</string>
		<string>Roadgeek2005SeriesD.ttf</string>
		<string>Roadgeek2005SeriesE.ttf</string>
		<string>Roadgeek2005SeriesEM.ttf</string>
		<string>Roadgeek2005Mittelschrift.ttf</string>
		<string>Roadgeek2005Engschrift.ttf</string>
		<string>ComicNeue-Regular.ttf</string>
		<string>ComicNeue-Bold.ttf</string>
	</array>

	<!-- location: keep updates flowing in the background for the Live Activity.
	     audio: "Audio, AirPlay, and Picture in Picture" — required for the
	     opt-in floating-window (PiP) feature. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>audio</string>
	</array>

	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
